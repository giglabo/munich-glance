# MunichGlance TRMNL Server Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=4567
DEBUG=false
TIME_ZONE=Europe/Berlin

# =============================================================================
# TRMNL Device Settings
# =============================================================================
# How often the device should refresh (seconds)
REFRESH_TIME=120

# Device identification
SETUP_FRIENDLY_ID=munich-glance
SETUP_MESSAGE=MunichGlance Dashboard

# Optional: API key for device authentication
# SETUP_API_KEY=your-secret-key

# =============================================================================
# MVG Departures Configuration
# =============================================================================
# Station name (will be resolved to station ID)
MVG_STATION_NAME=Marienplatz

# Or use station ID directly (takes precedence over name)
# MVG_STATION_ID=de:09162:2

# Number of departures to show (max ~10 fit on screen)
MVG_DEPARTURE_LIMIT=10

# Walking time to station in minutes (offsets departure times)
MVG_OFFSET_MINUTES=0

# Transport types to show (comma-separated)
# Options: UBAHN, SBAHN, TRAM, BUS, REGIONAL_BUS, BAHN, SCHIFF
MVG_TRANSPORT_TYPES=UBAHN,SBAHN,TRAM,BUS

# =============================================================================
# Weather Configuration
# =============================================================================
# Munich city center coordinates (default)
WEATHER_LAT=48.1351
WEATHER_LON=11.5820

# Temperature units: celsius or fahrenheit
WEATHER_UNITS=celsius

# =============================================================================
# Refresh Intervals (seconds)
# =============================================================================
# How often to fetch new departure data (minimum recommended: 60)
DEPARTURES_REFRESH_INTERVAL=60

# How often to fetch weather data (recommended: 900 = 15 minutes)
WEATHER_REFRESH_INTERVAL=900

# =============================================================================
# Display Options
# =============================================================================
# Show delay indicators (+X min)
SHOW_DELAYS=true

# Show platform/track numbers
SHOW_PLATFORM=false

# Show cancelled departures (with strikethrough)
SHOW_CANCELLED=true

# Time format: relative (5 min) or absolute (14:32)
TIME_FORMAT=relative

# Maximum minutes into future to show departures
MAX_MINUTES=60

# =============================================================================
# Cache Settings (seconds)
# =============================================================================
# Short cache for API failure fallback
DEPARTURES_CACHE_TTL=30

# Weather cache (should match refresh interval)
WEATHER_CACHE_TTL=900
